{
  "name": "catalog-data-access",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/catalog/data-access/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "domain:catalog",
    "type:data-access"
  ],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/catalog/data-access/ng-package.json",
        "tsConfig": "libs/catalog/data-access/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/catalog/data-access/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
